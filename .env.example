# Never commit your secret keys to version control. 
# Use the .env file to store your environment variables locally.
# Rename this file to .env and fill in the values for your Flutterwave public key, Supabase URL, and Supabase anon key.

VITE_FLUTTERWAVE_PUBLIC_KEY=
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
